---
import { withBase } from "../lib/paths";
import { homeIconPaths, type HomeFeature } from "../lib/home-content";

interface Props {
  item: HomeFeature;
  variant?: "feature" | "scope" | "compact";
}

const { item, variant = "feature" } = Astro.props as Props;

const detailHref = withBase(item.docHref);
---

<article class:list={["home-feature-card", `home-feature-card--${variant}`]}>
  <div class="home-feature-card__head">
    <span class="home-feature-card__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24">
        <path
          d={homeIconPaths[item.icon]}
          fill="none"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.8"
        />
      </svg>
    </span>
    <h3>{item.category}</h3>
  </div>

  {variant !== "scope" && item.highlights.length > 0 && (
    <ul class="home-feature-card__highlights">
      {item.highlights.map((line) => <li>{line}</li>)}
    </ul>
  )}

  {item.transforms.length > 0 && (
    <ul class="home-feature-card__transforms">
      {item.transforms.map((line) => <li>{line}</li>)}
    </ul>
  )}

  <a class="home-feature-card__link" href={detailHref}>Detaylı kullanım</a>
</article>
